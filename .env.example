# QQ 邮箱 SMTP 配置
# SMTP_USER 填发件邮箱，例如 4895557@qq.com
# SMTP_PASSWORD 填 QQ 邮箱“授权码”，不是登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=4895557@qq.com
SMTP_PASSWORD=replace_with_qq_smtp_authorization_code

# 收件人，英文逗号分隔
MAIL_TO=4895557@qq.com,834170548@qq.com

# 可选：雪球登录 Cookie。没有也能运行，但雪球搜索数据会跳过。
XUEQIU_COOKIE=

# 可选：节假日跳过日期、调休补班日期，格式 YYYY-MM-DD，多个日期用英文逗号分隔。
# 计划任务每天 08:00 触发，脚本会根据这些配置决定是否发送。
HOLIDAY_DATES=
WORKDAY_DATES=
